{
  "name": "@ceptesoft/async-result",
  "version": "0.1.0",
  "description": "Result discriminated-union types and a loading-flag wrapper that is guaranteed to clear — no more stuck spinners. Zero dependencies, framework-free.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "result",
    "discriminated-union",
    "loading",
    "async",
    "error-handling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ceptesoft/open-source-toolkit",
    "directory": "packages/async-result"
  },
  "publishConfig": {
    "access": "public"
  }
}
