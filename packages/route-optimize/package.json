{
  "name": "@ceptesoft/route-optimize",
  "version": "0.2.0",
  "description": "API-less route optimization: nearest-neighbor + 2-opt open tour over haversine distances, plus a keyless Google Maps directions URL builder. Pure, synchronous, zero dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "route-optimization",
    "tsp",
    "2-opt",
    "nearest-neighbor",
    "haversine",
    "google-maps",
    "waypoints"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ceptesoft/open-source-toolkit.git",
    "directory": "packages/route-optimize"
  },
  "publishConfig": {
    "access": "public"
  }
}
