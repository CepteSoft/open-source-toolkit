  "description": "Turkish phone number normalization and validation (05XXXXXXXXX canonical form). Zero dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
