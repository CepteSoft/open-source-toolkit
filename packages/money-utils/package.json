{
  "name": "@ceptesoft/money-utils",
  "version": "0.1.0",
  "description": "Safe monetary input parsing (comma decimals, overflow cap, NaN rejection), VAT gross/net math, and a parameter-driven currency registry. Zero dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "money",
    "currency",
    "vat",
    "kdv",
    "parsing",
    "erp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ceptesoft/open-source-toolkit",
    "directory": "packages/money-utils"
  },
  "publishConfig": {
    "access": "public"
  }
}
